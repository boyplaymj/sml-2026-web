      "secs": [
        { "h": "對敲交易", "body": "同一幅（及同類）畫作，數年間在多名『人頭買家』與數家『海外空殼公司』之間反覆高價對敲買賣，每次價格墊高，製造合法藝術品獲利的假象。" },
        { "h": "資金來源", "body": "投入資金來路不明。經此循環後，來路不明的髒錢被『洗』成看似合法的藝術品交易所得。" },
        { "h": "關鍵人", "body": "整條金流由藝廊負責人高博彥主導調度。大藏家郭崇德為其中一名人頭買家，以為買到真跡、資金卡在局中，才在拍場公開向沈維鈞施壓——他是被利用者，非主謀。" },
        { "h": "與命案的連結", "body": "沈維鈞的『非真跡』鑑定一旦出具，此畫即成贗品、整條洗錢金流當場崩解、並須負刑責。故有人必須讓這份報告永遠出不來。" }
      ],
