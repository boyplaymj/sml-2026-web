{
  "meta": {
    "title": "台灣十六張麻將 台數對照表",
    "purpose": "語音輸入判讀 + 手動選台共用的資料源。台數為可設定預設值,各家規則不同請自行調整。",
    "version": "0.1.0",
    "ruleset": "台灣16張(常見家規預設)",
    "usage": {
      "asr_vocabulary": "把每個台種的 name + aliases + asr_confusions 全部灌進雲端 ASR 的自訂詞庫(phrase hints),提升黑話辨識率。",
      "asr_correction": "辨識後先用 aliases/asr_confusions 做關鍵字比對與糾錯,再對應到 id。",
      "scoring": "累加各命中台種的 tai;注意 excludes(互斥)與 requires_self_draw(需自摸)。"
    },
    "notes": [
      "底(base)與台(tai)分開計:底是每局固定、台是牌型加成,結算另乘。",
      "門清自摸的算法家規分歧最大:有算門清1+自摸1=2、也有再加不求人=3。此表拆成獨立台種,由設定決定是否疊加。",
      "字一色 / 四暗刻 / 天地人胡 等大牌台數各地差異大,以下為常見值,請以你們賽制明文為準。"
    ]
  },

  "config": {
    "base_di": 1,
    "allow_stack_menqing_zimo": true,
    "comment": "base_di=每局底;allow_stack_menqing_zimo=門清與自摸是否可同時計台。"
  },

  "categories": ["莊家", "基本", "牌型", "字牌", "花牌", "時機", "大牌"],

